task.spawn(function()
    while true do
        task.wait(0.2)
        if AutoPlaceEnabled then
            local cookedMeat = getCookedMeat()
            if cookedMeat then
                if cookedMeat.Parent ~= LocalPlayer.Character then
                    cookedMeat.Parent = LocalPlayer.Character
                    task.wait(0.1)
                end
                local tables = getTables()
                for _, table in ipairs(tables) do
                    local free = true
                    for _, child in ipairs(table:GetChildren()) do
                        if child:IsA("Model") then
                            free = false
                            break
                        end
                    end
                    if free then
                        pcall(function() PlaceObjectRemote:FireServer(table, cookedMeat.Name) end)
                        task.wait(0.15)
                        break
                    end
                end
            end
        end
    end
end)

