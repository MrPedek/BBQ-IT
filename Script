local function ApplyThemeRealtime(ThemeTable)
    local targetGui = game:GetService("CoreGui"):FindFirstChild("Rayfield") or LocalPlayer:WaitForChild("PlayerGui"):FindFirstChild("Rayfield")
    if not targetGui then return end
    for _, obj in ipairs(targetGui:GetDescendants()) do
        if obj:IsA("Frame") or obj:IsA("ScrollingFrame") then
            if obj.Name == "Topbar" or obj.Name == "Header" or obj.Name == "TopFrame" then
                obj.BackgroundColor3 = ThemeTable.Topbar
            elseif obj.Name == "Main" or obj.Name == "Background" or obj.Name == "MainPanel" or obj.Name == "Elements" then
                obj.BackgroundColor3 = ThemeTable.Background
            elseif obj.Name == "Element" or obj.Name == "Container" or obj:GetAttribute("Element") or obj.Name == "Button" then
                obj.BackgroundColor3 = ThemeTable.ElementBackground
            elseif obj.Name == "TabButton" or obj.Name == "Tab" then
                if obj:GetAttribute("Selected") or (obj:FindFirstChild("Indicator") and obj.Indicator.Visible == true) then
                    obj.BackgroundColor3 = ThemeTable.TabBackgroundSelected
                else
                    obj.BackgroundColor3 = ThemeTable.ElementBackground
                end
            end
            if obj.Name == "SliderProgress" or obj.Name == "Fill" then
                obj.BackgroundColor3 = ThemeTable.SliderProgress
            elseif obj.Name == "ToggleIndicator" or obj.Name == "Switch" or obj.Name == "Toggled" then
                obj.BackgroundColor3 = ThemeTable.ToggleEnabled
            end
        elseif obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton") then
            obj.TextColor3 = ThemeTable.TextColor
        elseif obj:IsA("ImageLabel") and obj.Name == "Icon" then
            obj.ImageColor3 = ThemeTable.TextColor
        end
    end
end

local function CleanItemName(selectedOption)
    local rawText = type(selectedOption) == "table" and selectedOption[1] or selectedOption
    if not rawText then return "" end
    if OverridenRemoteArgs[rawText] then
        return OverridenRemoteArgs[rawText]
    end
    local cleaned = string.gsub(rawText, "%s*%(.-%)$", "")
    return cleaned
end

local function getPlayerLot()
