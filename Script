-- ====================== PETS (AUTO-COLLECT ONLY) ======================
local PickupObject = Remotes:FindFirstChild("PickupObject")
local PET_NAMES = {"Baby Dragon", "Cat", "Monkey", "Alien", "Dog", "Rat", "Worm", "Kangaroo"}

local function getPlacedPets()
    local lot = getPlayerLot()
    if not lot then return {} end
    local pets = {}
    for _, obj in ipairs(lot:GetChildren()) do
        for _, petName in ipairs(PET_NAMES) do
            if obj.Name == petName .. "_Placed" or obj.Name:find(petName) then
                table.insert(pets, obj)
                break
            end
        end
    end
    return pets
end

local function collectPet(petObject)
    if PickupObject then
        pcall(function() PickupObject:FireServer(petObject) end)
    end
end

