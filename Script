local function getCookingSpots()
    local lot = getPlayerLot()
    if not lot then return {} end
    local spots = {}
    for _, obj in ipairs(lot:GetChildren()) do
        if not obj.Name:find("Totem") and not obj.Name:find("Table") and not obj.Name:find("Trophy") and not obj.Name:find("Rat") then
            local grillSpots = obj:FindFirstChild("GrillSpots")
            if grillSpots and grillSpots:IsA("Folder") then
                for _, spot in ipairs(grillSpots:GetChildren()) do
                    if spot:IsA("BasePart") and spot.Name == "Part" then
                        table.insert(spots, spot)
                    end
                end
            end
        end
    end
    return spots
end

local function getTables()
    local lot = getPlayerLot()
    if not lot then return {} end
    local tables = {}
    for _, obj in ipairs(lot:GetChildren()) do
        if obj.Name:find("Table") then
            local plates = obj:FindFirstChild("Plates")
            if plates then
                for _, plate in ipairs(plates:GetChildren()) do
                    if plate:IsA("BasePart") then
                        table.insert(tables, plate)
                    end
                end
            end
        end
    end
    return tables
end

local function getRawMeat()
    local backpack = LocalPlayer.Backpack
    local character = LocalPlayer.Character
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower():find("raw") then
                return tool
            end
        end
    end
    if character then
        for _, tool in ipairs(character:GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower():find("raw") then
                return tool
            end
        end
    end
    return nil
end

