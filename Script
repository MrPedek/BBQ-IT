local key = "KF-XXXX-XXXX-XXXX"
local url = "https://www.keyforge.win/v1/load/cmqkajm2k000204jofss41h1n?script=cmqkan5jc000004jsbh411dx5&key=" .. key
local function kfFetch(u)
    local HttpService = game:GetService("HttpService")
    if HttpService.RequestAsync then
        local ok, res = pcall(function()
            return HttpService:RequestAsync({
                Url = u,
                Method = "GET",
                Headers = { ["X-KeyForge-Executor"] = "1" },
            })
        end)
        if ok and type(res) == "table" then
            return res.Body or ""
        end
    end
    local httpRequest = (syn and syn.request) or (http and http.request) or (fluxus and fluxus.request) or request or http_request
    if type(httpRequest) == "function" then
        local res = httpRequest({
            Url = u,
            Method = "GET",
            Headers = { ["X-KeyForge-Executor"] = "1" },
        })
        if type(res) == "table" then
            return res.Body or res.body or ""
        end
    end
    return game:HttpGet(u, true)
end
local body = kfFetch(url)
assert(type(body) == "string" and body ~= "", "[Keyforge Auth] loader fetch failed")
local _kf_ls = loadstring or load
assert(type(_kf_ls) == "function", "[Keyforge Auth] no loader function")
local fn, err = _kf_ls(body)
assert(fn, err or "load failed")
return fn()
