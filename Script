local PET_NAMES = {"Baby Dragon", "Cat", "Monkey", "Alien", "Dog", "Rat", "Worm", "Kangaroo"}

local function clickPlaceButton()
    local playerGui = LocalPlayerP:FindFirstChild("PlayerGui")
    if playerGui then
        local placementGui = playerGui:FindFirstChild("PlacementMobileGui")
        if placementGui then
            local placeBtn = placementGui:FindFirstChild("PlaceBtn")
            if placeBtn and placeBtn:IsA("TextButton") then
                local pos = placeBtn.AbsolutePosition
                local size = placeBtn.AbsoluteSize
                local x = pos.X + size.X/2
                local y = pos.Y + size.Y/2
                pcall(function()
                    vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
                    task.wait(0.05)
                    vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
                end)
                return true
            end
        end
    end
    return false
end

local function getSelectedInventoryPets(selectedNames)
    local pets = {}
    for _, tool in ipairs(LocalPlayerP.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            for _, selectedName in ipairs(selectedNames) do
                if tool.Name:find(selectedName) then
                    table.insert(pets, tool)
                    break
                end
            end
        end
    end
    return pets
end

local function getPlacedPetNames()
    local lot = workspace:FindFirstChild("PlayerLots") and workspace.PlayerLots:FindFirstChild(LocalPlayerP.Name)
    if not lot then return {} end
    local names = {}
    for _, obj in ipairs(lot:GetChildren()) do
        for _, petName in ipairs(PET_NAMES) do
            if obj.Name == petName .. "_Placed" or obj.Name:find(petName) then
                names[petName] = true
                break
            end
        end
    end
    return names
end

local function placePet(petTool)
    if not petTool then return false end
    petTool.Parent = LocalPlayerP.Character
    task.wait(0.15)
    return clickPlaceButton()
end

local function collectPet(petObject)
    if PickupObject then
        pcall(function() PickupObject:FireServer(petObject) end)
    end
end

